{
  "name": "keynote-clipboard",
  "version": "0.1.0",
  "description": "Parser for Keynote clipboard canvas objects",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    }
  },
  "bin": {
    "keynote-clipboard": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run test",
    "test:watch": "vitest test",
    "inspect": "tsx src/cli.ts inspect complex-keynote-clipboard.json --pretty --diagnostics",
    "svg": "tsx src/cli.ts svg complex-keynote-clipboard.json --out example.svg --diagnostics --pretty",
    "tikz": "tsx src/cli.ts tikz complex-keynote-clipboard.json --out example.tikz --diagnostics --pretty"
  },
  "keywords": [
    "keynote",
    "clipboard",
    "parser"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@skgrush/bplist-and-nskeyedunarchiver": "^0.0.1-rc.2"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
